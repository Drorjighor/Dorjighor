# Brevo SMTP settings for Vercel serverless functions.
# Set these in Vercel Project Settings -> Environment Variables.
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER="a8ad7d001@smtp-brevo.com"
BREVO_SMTP_PASS="your-brevo-smtp-password"

# Sender and receiver emails used by the contact/newsletter APIs.
MAIL_FROM="no-reply@dorjighor.com.bd"
MAIL_TO="support@dorjighor.com.bd"
